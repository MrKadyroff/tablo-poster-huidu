{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Kestrel will listen on this URL when running locally.
  // In production as a Windows Service, change port as needed.
  "Urls": "http://localhost:5050",
  // ─── Active point ─────────────────────────────────────────────────────────
  // Change this to switch which branch/point the service runs for.
  // The matching config/points/{ActivePointId}.json will be loaded on top of this file.
  "ActivePointId": "zeleny-bazar",
  // ─── Telegram notifications (optional) ───────────────────────────────────────
  // Set Enabled=true and fill BotToken (@BotFather) + ChatId to get alerts when a
  // push to the board fails / recovers. Leave Enabled=false to disable silently.
  "Telegram": {
    "Enabled": false,
    "BotToken": "",
    "ChatId": ""
  },
  // ─── Global service settings (shared across all points) ──────────────────
  "LedUpdater": {
    "RunMode": "RenderOnly",
    "PublishMode": "WifiFtp",
    "PollSeconds": 10,
    "FtpUser": "guest",
    "FtpPassword": "guest",
    "UseTls": false,
    "FtpPort": 21,
    "SkipIfUnchanged": true,
    // true = recompose every poll cycle (ignore change detection).
    "ForceComposeEveryPoll": false,
    // true = force RenderOnly and disable board auto-send for layout testing.
    "LayoutTestMode": false,
    // true (default) = point has permanent internet: rates fetched, image rendered AND auto-sent
    // to the board on the poll timer. false = no stable internet: rates/image still update, but the
    // board is sent only manually via the "Отправить на табло" button on the Design tab.
    "PermanentInternet": true,
    "EnforceWifiOnly": false,
    "RequirePrivateAddress": true,
    // Live rate fetching — applies to ALL points (index.json maps depCode per point)
    "RatesApiUrl": "https://api.quiq.kz/Department/getDepsLandingInfo",
    "RatesFetchIntervalMinutes": 1,
    // ─── Point-specific values below are injected from config/points/{ActivePointId}.json ───
    // WatchFolder, ScreenXmlPath, ComposeConfigPath, RatesJsonPath,
    // ForceRemoteRoot, NetworkJsonPath, RelayOutRoot, ControllerReloadUrl
    "WatchFolder": "",
    "ScreenXmlPath": "config/screen.xml"
  },
  // ─── LED controller family ──────────────────────────────────────────────────
  // This application drives Huidu / HDPlayer cards (e.g. BX A3L) only.
  // The Onbon BX-Y family lives in the separate "eCash Tablo" application.
  "Led": {
    "Family": "Huidu"
  },
  // ─── Huidu (HDPlayer) configuration ──────────────────────────────────────────
  // Client mode (HDPlayer protocol): this service CONNECTS to the card at CardIp:CardPort.
  // In Wi-Fi AP mode the BX A3L is the gateway (e.g. 192.168.43.1). Leave CardIp empty to
  // auto-discover the card via UDP broadcast on port 9527.
  "HuiduLed": {
    "Enabled": true,
    "ListenPort": 6677,
    // Card serial (from the capture). Used to pick the right card during UDP auto-discovery.
    "DeviceId": "A3L-25-A027F",
    "ScreenWidth": 1216,
    "ScreenHeight": 192,
    "ProgramTemplatePath": "config/huidu/program-template.xml",
    "AutoConfigureViaUdp": true,
    // Card address. In Wi-Fi AP mode the BX A3L is the gateway = 192.168.43.1 (from the capture).
    // Set empty ("") to auto-discover via UDP broadcast on port 9527 instead.
    "CardIp": "192.168.43.1",
    // TCP port the card listens on for the HDPlayer protocol (Huidu default 10001).
    "CardPort": 10001,
    "ConnectWaitSeconds": 15,
    "IoTimeoutMs": 10000,
    // LedBoardService polling interval (seconds).
    "PollSeconds": 10,
    // false = generate images automatically but do NOT auto-send to board.
    "AutoSend": true,
    "SkipDuplicateUploads": true,
    "RejectSizeMismatchBeforePublish": false,
    // ─── Board-link monitor (auto-detect card when PC joins the table's Wi-Fi) ──
    // Watches for the PC switching onto the card's AP (private IP, no internet — the
    // AnyDesk case), auto-discovers the card, runs ping/TCP/hello diagnostics, and
    // auto-sets CardIp when it differs. See GET /api/led/board-link.
    "AutoDetectOnApLink": true,
    "AutoApplyCardIp": true,
    "AutoApplyScreenSize": true,
    "BoardLinkPollSeconds": 30
  }
}